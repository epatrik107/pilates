rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Server-side capacity guard – prevents bookings on full classes
    // even if a malicious client bypasses the UI/transaction logic.
    function classHasCapacity(classId) {
      let cls = get(/databases/$(database)/documents/classes/$(classId));
      return cls != null && cls.data.currentBookings < cls.data.maxCapacity;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBookings'])
          && request.resource.data.currentBookings is int
          && request.resource.data.currentBookings >= 0
          && request.resource.data.currentBookings <= resource.data.maxCapacity
        );
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.classId is string
        && classHasCapacity(request.resource.data.classId);
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['calendarEventId']);
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
