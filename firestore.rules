rules_version = '2';

// ═══════════════════════════════════════════════════════════
// App Check ENFORCEMENT must be enabled in Firebase Console:
// Firebase Console → App Check → Apps → Enforce (Firestore + Auth)
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function validName(data) {
      return data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 100;
    }

    function validBirthdayFields(data) {
      return (
        (!('birthdayDate' in data) && !('birthdayMonthDay' in data))
        || (data.birthdayDate == null && data.birthdayMonthDay == null)
        || (
          data.birthdayDate is string
          && data.birthdayDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
          && data.birthdayMonthDay is string
          && data.birthdayMonthDay.matches('^\\d{2}-\\d{2}$')
        )
      );
    }

    function userChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function validEmailUpdate() {
      return !userChangedKeys().hasAny(['email'])
        || (
          request.auth.token.email_verified == true
          && request.resource.data.email == request.auth.token.email
        );
    }

    function validBirthdayUpdate() {
      return !userChangedKeys().hasAny(['birthdayDate', 'birthdayMonthDay'])
        || (
          (!('birthdayDate' in resource.data) || resource.data.birthdayDate == null)
          && request.resource.data.birthdayDate is string
          && request.resource.data.birthdayDate.matches('^\\d{4}-\\d{2}-\\d{2}$')
          && request.resource.data.birthdayMonthDay is string
          && request.resource.data.birthdayMonthDay.matches('^\\d{2}-\\d{2}$')
        );
    }

    function validPhotoUpdate() {
      return !userChangedKeys().hasAny(['photoURL'])
        || (
          request.resource.data.photoURL is string
          && request.resource.data.photoURL.size() <= 700000
        );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'name', 'email', 'role', 'createdAt', 'birthdayDate', 'birthdayMonthDay', 'photoURL'
        ])
        && request.resource.data.keys().hasAll(['name', 'email', 'role', 'createdAt'])
        && request.resource.data.role == 'user'
        && validName(request.resource.data)
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.createdAt is string
        && validBirthdayFields(request.resource.data)
        && (
          !('photoURL' in request.resource.data)
          || request.resource.data.photoURL is string
        );
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.name == resource.data.name
        && request.resource.data.createdAt == resource.data.createdAt
        && userChangedKeys().hasOnly(['email', 'birthdayDate', 'birthdayMonthDay', 'photoURL'])
        && validEmailUpdate()
        && validBirthdayUpdate()
        && validPhotoUpdate();
      allow delete: if isOwner(userId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, delete: if false;
      allow update: if isSignedIn()
        && (
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['calendarEventId'])
            && request.resource.data.calendarEventId is string
            && request.resource.data.calendarEventId.size() <= 512
          )
          || (
            isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attended'])
            && request.resource.data.attended is bool
          )
        );
    }

    match /waitlist/{waitlistId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasOnly([
          'userId', 'userName', 'userEmail', 'classId', 'classTitle', 'classDate', 'addedAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 100
        && request.resource.data.classId is string
        && request.resource.data.classTitle is string
        && request.resource.data.classDate is string;
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
