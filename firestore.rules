rules_version = '2';

// ═══════════════════════════════════════════════════════════
// App Check ENFORCEMENT must be enabled in Firebase Console:
// Firebase Console → App Check → Apps → Enforce (Firestore + Auth)
// Without enforcement, bots can bypass these rules entirely.
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Server-side capacity guard – prevents bookings on full classes
    // even if a malicious client bypasses the UI/transaction logic.
    function classHasCapacity(classId) {
      let cls = get(/databases/$(database)/documents/classes/$(classId));
      return cls != null && cls.data.currentBookings < cls.data.maxCapacity;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.keys().hasAll(['name', 'email', 'role']);
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100;
      allow delete: if isOwner(userId);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentBookings'])
          && request.resource.data.currentBookings is int
          && request.resource.data.currentBookings >= 0
          && request.resource.data.currentBookings <= resource.data.maxCapacity
        );
    }

    // 24-hour cancellation policy – server-side enforcement
    function canUserCancelBooking() {
      // Backward compat: bookings without classStartTimestamp are unrestricted
      return !('classStartTimestamp' in resource.data)
        // More than 24 hours before class start
        || request.time < (resource.data.classStartTimestamp - duration.value(24, 'h'))
        // Grace period: within 5 minutes of booking creation
        || ('bookedAt' in resource.data && resource.data.bookedAt != null
            && request.time < (resource.data.bookedAt + duration.value(5, 'm')));
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && (
          // Normal user booking
          (
            request.resource.data.userId == request.auth.uid
            && request.resource.data.userName is string
            && request.resource.data.userName.size() <= 100
            && request.resource.data.userEmail is string
          )
          // Admin booking on behalf of a user
          || isAdmin()
        )
        && request.resource.data.classId is string
        && request.resource.data.classTitle is string
        && request.resource.data.classDate is string
        && request.resource.data.keys().hasAll(['userId', 'classId', 'userName', 'userEmail', 'classTitle', 'classDate'])
        && classHasCapacity(request.resource.data.classId);
      allow update: if isSignedIn()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['calendarEventId'])
          || (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attended']))
        );
      allow delete: if isSignedIn()
        && (
          isAdmin()
          || (resource.data.userId == request.auth.uid && canUserCancelBooking())
        );
    }

    match /waitlist/{waitlistId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.classId is string
        && request.resource.data.userName is string
        && request.resource.data.classDate is string;
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
